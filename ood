#!/usr/bin/env bash

set -e

BASE_DIR="$(cd "$(dirname "$0")" && pwd)"

VENV_DIR="$BASE_DIR/.venv"
REQUIREMENTS="$BASE_DIR/requirements.txt"
ASTRO_DIR="$BASE_DIR/astro.docs"
ASTRO_NODE_MODULES="$ASTRO_DIR/node_modules"
FASTAPI_CACHE="$BASE_DIR/fastapi.docs/.cache"
ALPINE_CACHE="$BASE_DIR/alpine.docs/.cache"

PHP_PORT=8002
ASTRO_PORT=8003
PYTHON_PORT=8001
ALPINE_PORT=8004
FASTAPI_PORT=8000

ONLY=""
STOP=false
CLEAN=false
STREAM=false
RUN_ALL=false

while [[ $# -gt 0 ]]; do
  case "$1" in
    clean)
      CLEAN=true
      shift
      ;;
    --only)
      ONLY="$2"
      shift 2
      ;;
    --all)
      RUN_ALL=true
      shift
      ;;
    --stream)
      STREAM=true
      shift
      ;;
    --port)
      IFS='=' read -r name port <<< "$2"
      case "$name" in
        php) PHP_PORT=$port ;;
        python) PYTHON_PORT=$port ;;
        fastapi) FASTAPI_PORT=$port ;;
        alpine) ALPINE_PORT=$port ;;
        astro) ASTRO_PORT=$port ;;
        *) echo "Unknown service for --port: $name"; exit 1 ;;
      esac
      shift 2
      ;;
    stop)
      STOP=true
      shift
      ;;
    *)
      echo "Unknown argument: $1"
      exit 1
      ;;
  esac
done

setup_python_env() {
  if [ ! -d "$VENV_DIR" ]; then
    echo "[setup] Creating Python virtual environment..."
    python3 -m venv "$VENV_DIR"
    echo "[setup] Virtual environment created at $VENV_DIR"
  else
    echo "[setup] Virtual environment already exists"
  fi

  if [ -z "$VIRTUAL_ENV" ]; then
    echo "[setup] Activating virtual environment..."
    source "$VENV_DIR/bin/activate"
  else
    echo "[setup] Virtual environment already active: $VIRTUAL_ENV"
  fi

  if [ -f "$REQUIREMENTS" ]; then
    echo "[setup] Installing/updating Python packages..."
    pip install -q -r "$REQUIREMENTS" 2>/dev/null || true
    echo "[setup] Python packages installed"
  else
    echo "[setup] No requirements.txt found"
  fi
}

setup_astro_env() {
  if [ ! -d "$ASTRO_DIR" ]; then
    echo "[setup] Astro docs directory not found, skipping Astro setup"
    return
  fi

  if [ ! -d "$ASTRO_NODE_MODULES" ]; then
    echo "[setup] Installing Astro dependencies..."
    cd "$ASTRO_DIR"
    pnpm install 2>/dev/null || true
    cd "$BASE_DIR"
    echo "[setup] Astro dependencies installed"
  else
    echo "[setup] Astro dependencies already installed"
  fi
}

clean_all() {
  echo "[clean] Cleaning up environment..."

  stop_all

  if [ -d "$VENV_DIR" ]; then
    echo "[clean] Removing Python virtual environment..."
    rm -rf "$VENV_DIR"
    echo "[clean] Removed $VENV_DIR"
  fi

  if [ -d "$ASTRO_NODE_MODULES" ]; then
    echo "[clean] Removing Astro node_modules..."
    rm -rf "$ASTRO_NODE_MODULES"
    echo "[clean] Removed $ASTRO_NODE_MODULES"
  fi

  if [ -d "$FASTAPI_CACHE" ]; then
    echo "[clean] Removing FastAPI cache..."
    rm -rf "$FASTAPI_CACHE"
    echo "[clean] Removed $FASTAPI_CACHE"
  fi

  if [ -d "$ALPINE_CACHE" ]; then
    echo "[clean] Removing Alpine cache..."
    rm -rf "$ALPINE_CACHE"
    echo "[clean] Removed $ALPINE_CACHE"
  fi

  if [ -d "$ASTRO_DIR/.astro" ]; then
    echo "[clean] Removing Astro .astro build directory..."
    rm -rf "$ASTRO_DIR/.astro"
    echo "[clean] Removed $ASTRO_DIR/.astro"
  fi

  if [ -d "$ASTRO_DIR/dist" ]; then
    echo "[clean] Removing Astro dist directory..."
    rm -rf "$ASTRO_DIR/dist"
    echo "[clean] Removed $ASTRO_DIR/dist"
  fi

  echo "[clean] Cleanup complete."
}

stop_all() {
  echo "Stopping all docs servers..."

  for port in $PHP_PORT $PYTHON_PORT $FASTAPI_PORT $ALPINE_PORT $ASTRO_PORT; do
    pid=$(lsof -ti ":$port" 2>/dev/null || true)
    if [ -n "$pid" ]; then
      kill "$pid" 2>/dev/null || true
      echo "  [stop] Killed process on port $port (PID: $pid)"
    fi
  done

  pkill -f "mkdocs serve.*$FASTAPI_PORT" 2>/dev/null || true
  pkill -f "mkdocs serve.*$ALPINE_PORT" 2>/dev/null || true
  pkill -f "pnpm dev.*$ASTRO_PORT" 2>/dev/null || true

  echo "Done."
}

run_php() {
  if [ -d "$BASE_DIR/php.docs" ]; then
    echo "[php] -> http://127.0.0.1:$PHP_PORT"

    if $STREAM; then
        (cd "$BASE_DIR/php.docs" && python -m http.server "$PHP_PORT") &
    else
        (cd "$BASE_DIR/php.docs" && python -m http.server "$PHP_PORT" 2>/dev/null || true) &
    fi
  else
    echo "[php] skipped (dir missing)"
  fi
}

run_python() {
  if [ -d "$BASE_DIR/python.docs" ]; then
    echo "[python] -> http://127.0.0.1:$PYTHON_PORT"

    if $STREAM; then
        (cd "$BASE_DIR/python.docs" && python -m http.server "$PYTHON_PORT") &
    else
        (cd "$BASE_DIR/python.docs" && python -m http.server "$PYTHON_PORT" 2>/dev/null || true) &
    fi
  else
    echo "[python] skipped (dir missing)"
  fi
}

run_fastapi() {
  if [ -d "$BASE_DIR/fastapi.docs" ]; then
    echo "[fastapi] -> http://127.0.0.1:$FASTAPI_PORT"

    if $STREAM; then
       (cd "$BASE_DIR/fastapi.docs" && source "$VENV_DIR/bin/activate" && mkdocs serve -a 127.0.0.1:$FASTAPI_PORT) &
    else
        (cd "$BASE_DIR/fastapi.docs" && source "$VENV_DIR/bin/activate" && mkdocs serve -a 127.0.0.1:$FASTAPI_PORT 2>/dev/null || true) &
    fi
  else
    echo "[fastapi] skipped (dir missing)"
  fi
}

run_alpine() {
  if [ -d "$BASE_DIR/alpine.docs" ]; then
    echo "[alpine] -> http://127.0.0.1:$ALPINE_PORT"
    (cd "$BASE_DIR/alpine.docs" && source "$VENV_DIR/bin/activate" && mkdocs serve -a 127.0.0.1:$ALPINE_PORT) &
  else
    echo "[alpine] skipped (dir missing)"
  fi
}

run_astro() {
  if [ -d "$BASE_DIR/astro.docs" ]; then
    echo "[astro] -> http://127.0.0.1:$ASTRO_PORT"
    (cd "$BASE_DIR/astro.docs" && pnpm dev --port "$ASTRO_PORT" --host 127.0.0.1) &
  else
    echo "[astro] skipped (dir missing)"
  fi
}

run_selected() {
  IFS=',' read -ra SERVICES <<< "$ONLY"
  for svc in "${SERVICES[@]}"; do
    case "$svc" in
      php) run_php ;;
      python) run_python ;;
      fastapi) run_fastapi ;;
      alpine) run_alpine ;;
      astro) run_astro ;;
      *) echo "Unknown service: $svc" ;;
    esac
  done
}

run_all() {
  run_php
  run_python
  run_fastapi
  run_alpine
  run_astro
}

if $CLEAN; then
  clean_all
  exit 0
fi

if $STOP; then
  stop_all
  exit 0
fi

needs_python_env=false
needs_astro_env=false

if $RUN_ALL; then
  needs_python_env=true
  needs_astro_env=true
elif [ -n "$ONLY" ]; then
  IFS=',' read -ra SERVICES <<< "$ONLY"
  for svc in "${SERVICES[@]}"; do
    if [[ "$svc" == "fastapi" ]] || [[ "$svc" == "alpine" ]]; then
      needs_python_env=true
    fi
    if [[ "$svc" == "astro" ]]; then
      needs_astro_env=true
    fi
  done
fi

if $needs_python_env; then
  setup_python_env
fi

if $needs_astro_env; then
  setup_astro_env
fi

if $RUN_ALL; then
  run_all
elif [ -n "$ONLY" ]; then
  run_selected
else
  echo
  echo "Usage:"
  echo "  bash ood --all --stream"
  echo "  bash ood --only php,astro --stream"
  echo "  bash ood --only fastapi --port fastapi=9000 --stream"
  echo "  bash ood stop"
  echo "  bash ood clean"
  echo
  echo "Options:"
  echo "  --all: starts all documentation services"
  echo "  --only: starts specified documentation services"
  echo "  --port: starts specified documentation service on the given port number"
  echo "  --stream: to stream all logs related to services running, omit if not needed"
  echo
  exit 1
fi

wait
