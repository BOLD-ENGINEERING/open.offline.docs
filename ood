#!/usr/bin/env bash

set -e

# Load .env if it exists
SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
if [ -f "$SCRIPT_DIR/.env" ]; then
  set -a
  source "$SCRIPT_DIR/.env"
  set +a
fi

# Source all modular scripts
SCRIPTS_DIR="$SCRIPT_DIR/scripts"

source "$SCRIPTS_DIR/vars.sh"
source "$SCRIPTS_DIR/flags.sh"
source "$SCRIPTS_DIR/docker.sh"
source "$SCRIPTS_DIR/functions.sh"

# Command execution
if $BUILD; then
  docker_build
  exit 0
fi

if $UP; then
  docker_up
  exit 0
fi

if $DOWN; then
  docker_down
  exit 0
fi

if $STOP; then
  docker_down
  exit 0
fi

if $CLEAN; then
  docker_clean
  exit 0
fi

if $STATUS; then
  docker_status
  exit 0
fi

if $LIST; then
  run_list
  exit 0
fi

if $HELP; then
  run_help
  exit 0
fi

if $DOCTOR; then
  run_doctor
  exit 0
fi

if $TUI; then
  run_tui
  exit 0
fi

# No command specified - show notice
run_notice